POSTGRES_DSN=postgresql://suricatha:SENHA_FORTE@localhost:5432/suricatha_db

UPLOAD_DIR=/home/camera_lpr/uploads
STORAGE_DIR=/opt/suricatha/storage
LOG_DIR=/opt/suricatha/logs

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

OCR_CPU_THREADS=4
OCR_USE_MKLDNN=true
OCR_MIN_CONFIDENCE=0.55
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
UPLOAD_DELAY_S=0.5
WORKER_THREADS=2

# gere com: openssl rand -hex 32
JWT_SECRET=TROQUE_POR_TOKEN_SEGURO
JWT_EXPIRE_HOURS=720
# gere com: openssl rand -hex 24
API_KEYS=TROQUE_POR_APIKEY_SEGURA

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

WA_PROVIDER=evolution
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_PHONE=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_PHONE=

REPORT_DIR=/opt/suricatha/reports
REPORT_HOUR=6

LPR_WORKERS=2
ANALYTICS_WORKERS=2
QUEUE_MAXSIZE=500

YOLO_PEOPLE_MODEL=/opt/suricatha/models/yolov8n.pt
YOLO_PPE_MODEL=/opt/suricatha/models/yolov8n-ppe.pt
YOLO_CPU_THREADS=4
PEOPLE_CONF_THRESHOLD=0.45
PPE_CONF_THRESHOLD=0.40
PPE_CLASS_MAP={"0":"helmet","1":"no-helmet"}

RTMP_HOST=SEU_IP_OU_DOMINIO
RTMP_PORT=1935
